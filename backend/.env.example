# Preferred: paste your Supabase Postgres connection URL here.
SUPABASE_DB_URL=postgresql://postgres:p2OzUz3yRJVaTFsr@db.awqbnagyzdnmvqpezzah.supabase.co:5432/postgres

# Optional override. If omitted, backend derives this from SUPABASE_DB_URL.
SUPABASE_PROJECT_URL=https://awqbnagyzdnmvqpezzah.supabase.co

# Required for backend uploads to Supabase Storage.
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
SUPABASE_STORAGE_BUCKET=posts
SUPABASE_MAX_UPLOAD_MB=10

# Required for song search via Spotify Web API.
SPOTIFY_CLIENT_ID=replace_with_spotify_client_id
SPOTIFY_CLIENT_SECRET=replace_with_spotify_client_secret
SPOTIFY_SEARCH_MAX_RESULTS=8
SPOTIFY_TOKEN_BUFFER_SECONDS=60
# Optional. Example: IN, US, GB. Leave blank to let Spotify choose defaults.
SPOTIFY_SEARCH_MARKET=

# Optional local fallback (not needed when using Supabase).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/creator_growth
JWT_SECRET_KEY=change_me_in_production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256
CORS_ORIGINS=http://localhost:3000
